# ── Required for Production (Render) ──────────────
# Get free at console.groq.com — no credit card needed
GROQ_API_KEY=

# Random 32-char string for JWT signing (auto-generated if not set)
SECRET_KEY=

# Frontend URL for CORS (your Vercel URL)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:8003

# ── Optional ──────────────────────────────────────
# Local LLM (default: ollama with llama3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# GitHub integration
GITHUB_TOKEN=

# Data directory (default: ./database)
# MINTUU_DATA_DIR=/data

# Environment (development/production)
ENVIRONMENT=development

# Log level
LOG_LEVEL=INFO
